rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // HELPER FUNCTIONS
    // =========================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(
          /databases/$(database)/documents/users/$(request.auth.uid)
        ).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() &&
        request.auth.uid == userId;
    }

    // =========================
    // USERS
    // =========================
    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isAdmin();

      allow update: if
        isAdmin()
        ||
        (
          isOwner(userId)
          &&
          request.resource.data
            .diff(resource.data)
            .affectedKeys()
            .hasOnly([
              'deviceId',
              'lastSeen'
            ])
        );

      allow delete: if isAdmin();
    }

    // =========================
    // PRESENSI
    // =========================
    match /presensi/{docId} {
      allow read: if isSignedIn();

      allow create: if
        isSignedIn()
        &&
        request.resource.data.uid
          == request.auth.uid
        &&
        request.resource.data.tanggal
          == string(request.time.date());

      allow update, delete: if false;
    }

    // =========================
    // LOKASI
    // =========================
    match /lokasi/{lokasiId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // =========================
    // SYSTEM SETTINGS
    // =========================
    match /system_settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}